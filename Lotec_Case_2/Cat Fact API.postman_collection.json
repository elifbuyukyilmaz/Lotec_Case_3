      "item": [
        {
          "name": "/fact",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is JSON\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has fact and length fields\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData).to.have.property(\"fact\");\r",
                  "    pm.expect(jsonData).to.have.property(\"length\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Fact should be within the max_length=100 limit\", () => {\r",
                  "    const json = pm.response.json();\r",
                  "\r",
                  "        pm.expect(json.fact.length).to.be.at.most(70);\r",
                  "}); \r",
                  "\r",
                  "pm.test(\"Fact is string\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData.fact).to.be.a(\"string\");\r",
                  "   \r",
                  "});\r",
                  "pm.test(\"Length is number \", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData.length).to.be.a(\"number\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fact?max_length=70",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fact"
              ],
              "query": [
                {
                  "key": "max_length",
                  "value": "70",
                  "description": "maximum length of returned fact"
                }
              ]
            }
          },
          "response": []
        },
